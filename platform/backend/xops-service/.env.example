# xops-service 환경변수 (XOPS_ 접두사). 복사: cp .env.example .env
# 프로덕션에서는 XOPS_ENVIRONMENT=prod + XOPS_JWT_SECRET 지정 필수(미지정 시 기동 거부).

XOPS_ENVIRONMENT=dev
# XOPS_JWT_SECRET=change-me-in-prod
# XOPS_CORS_ORIGINS=["http://localhost:5173"]

# 임계치(기본값 표기) — 필요 시 조정
# XOPS_PSI_THRESHOLD=0.2
# XOPS_KL_THRESHOLD=0.1
# XOPS_ZSCORE_THRESHOLD=3.0
# XOPS_IQR_MULTIPLIER=1.5
# XOPS_ROLLBACK_LATENCY_MS=200
# XOPS_RETRAIN_MIN_INTERVAL_MINUTES=30
